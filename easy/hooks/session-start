#!/usr/bin/env bash
# SessionStart hook for tw-easy plugin

set -euo pipefail

session_context="You have the tw-easy plugin installed.\n\nAvailable slash commands:\n- /easy — Lightweight development: clarify requirements then hand off to Claude Code native plan & code\n- /clarify — Requirements clarification (backend or frontend scenario)\n\nThese skills are ONLY activated when the user explicitly invokes them via slash command.\nDo NOT auto-invoke these skills based on user intent or keywords. Only use them when the user types the slash command."

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
