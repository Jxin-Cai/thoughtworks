#!/usr/bin/env bash
# SessionStart hook for thoughtworks-frontend plugin

set -euo pipefail

session_context="You have the thoughtworks-frontend plugin installed.\n\nAvailable slash commands:\n- /thoughtworks-skills-frontend — Frontend end-to-end workflow consuming DDD API contracts\n- /thoughtworks-skills-clarify — Requirements clarification (use with 'frontend' scenario)\n- /thoughtworks-skills-frontend-thought — Frontend design phase\n- /thoughtworks-skills-frontend-works — Frontend coding phase\n- /thoughtworks-branch — Git feature branch management\n- /thoughtworks-skills-merge — Squash merge feature branch back to main/master\n\nThese skills are ONLY activated when the user explicitly invokes them via slash command.\nDo NOT auto-invoke these skills based on user intent or keywords. Only use them when the user types the slash command."

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
