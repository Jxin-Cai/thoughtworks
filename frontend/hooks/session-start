#!/usr/bin/env bash
# SessionStart hook for thoughtworks-frontend plugin

set -euo pipefail

session_context="<EXTREMELY_IMPORTANT>\nYou have the thoughtworks-frontend plugin installed.\n\nWhen the user's request involves frontend development based on DDD API contracts, you MUST invoke the relevant skill BEFORE any response.\n\n| User Intent | Skill to Invoke |\n|---|---|\n| Frontend end-to-end | thoughtworks-skills-frontend |\n| Frontend requirements clarification | thoughtworks-skills-frontend-clarify |\n| Frontend design only | thoughtworks-skills-frontend-thought |\n| Frontend coding only | thoughtworks-skills-frontend-works |\n| Frontend coding spec | thoughtworks-skills-frontend-spec |\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
