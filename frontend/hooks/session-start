#!/usr/bin/env bash
# SessionStart hook for thoughtworks-frontend plugin

set -euo pipefail

session_context="<EXTREMELY_IMPORTANT>\nYou have the thoughtworks-frontend plugin installed.\n\nWhen the user's request involves frontend development based on DDD API contracts, prioritize invoking the relevant skill first.\n\nFor requests that are clearly outside frontend workflow (e.g., code audit, architecture explanation, targeted fixes), direct response is allowed and skill invocation is optional.\n\n| User Intent | Skill to Invoke |\n|---|---|\n| Frontend end-to-end | thoughtworks-skills-frontend |\n| Clarify frontend requirements | thoughtworks-skills-frontend-clarify |\n| Frontend design only | thoughtworks-skills-frontend-thought |\n| Frontend coding only | thoughtworks-skills-frontend-works |\n\nUse the Skill tool to invoke these skills when applicable.\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
