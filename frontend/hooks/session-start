#!/usr/bin/env bash
# SessionStart hook for tw-frontend plugin

set -euo pipefail

session_context="You have the tw-frontend plugin installed.\n\nAvailable slash commands:\n- /frontend — Frontend end-to-end workflow consuming DDD API contracts\n- /clarify — Requirements clarification (use with 'frontend' scenario)\n- /frontend-thought — Frontend design phase\n- /frontend-works — Frontend coding phase\n- /branch — Git feature branch management\n- /merge — Squash merge feature branch back to main/master\n\nThese skills are ONLY activated when the user explicitly invokes them via slash command.\nDo NOT auto-invoke these skills based on user intent or keywords. Only use them when the user types the slash command."

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
