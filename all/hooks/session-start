#!/usr/bin/env bash
# SessionStart hook for tw-all plugin (fullstack)

set -euo pipefail

session_context="You have the tw-all plugin installed.\n\nAvailable slash commands:\n- /all — Fullstack DDD workflow: orchestrates backend and frontend in sequence\n- /backend — Backend DDD end-to-end workflow\n- /frontend — Frontend end-to-end workflow consuming DDD API contracts\n- /branch — Git feature branch management\n- /merge — Squash merge feature branch back to main/master\n\nThese skills are ONLY activated when the user explicitly invokes them via slash command.\nDo NOT auto-invoke these skills based on user intent or keywords. Only use them when the user types the slash command."

# Output context injection as JSON.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
