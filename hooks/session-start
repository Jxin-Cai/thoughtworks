#!/usr/bin/env bash
# SessionStart hook for thoughtworks-all plugin (fullstack)

set -euo pipefail

# Compact trigger index — full content loaded on-demand via Skill tool
session_context="<EXTREMELY_IMPORTANT>\nYou have the thoughtworks-all plugin installed.\n\nWhen the user's request involves DDD, domain modeling, layered architecture, Java code generation, or frontend development based on DDD API contracts, you MUST use the Skill tool to invoke the relevant skill BEFORE any other action — no exploring, no reading files, no writing code.\n\n| User Intent | Invoke via Skill tool |\n|---|---|\n| Backend DDD | Skill(skill: \"thoughtworks-skills-backend\", args: \"<requirement>\") |\n| Frontend consuming DDD APIs | Skill(skill: \"thoughtworks-skills-frontend\", args: \"<idea-name>\") |\n| Fullstack end-to-end | Skill(skill: \"thoughtworks-skills-all\", args: \"<requirement>\") |\n\nDo NOT follow the workflow steps manually. The skill handles all internal steps, HARD-GATEs, and state management.\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
