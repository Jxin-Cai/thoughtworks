#!/usr/bin/env bash
# SessionStart hook for thoughtworks-backend plugin

set -euo pipefail

session_context="<EXTREMELY_IMPORTANT>\nYou have the thoughtworks-backend plugin installed.\n\nWhen the user's request involves DDD, domain modeling, layered architecture, or Java code generation, you MUST invoke the relevant skill BEFORE any response.\n\n| User Intent | Skill to Invoke |\n|---|---|\n| Backend DDD end-to-end | thoughtworks-skills-ddd |\n| Clarify backend requirements | thoughtworks-skills-ddd-clarify |\n| Backend design only | thoughtworks-skills-ddd-thought |\n| Backend coding only | thoughtworks-skills-ddd-works |\n\nUse the Skill tool to invoke these skills.\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
